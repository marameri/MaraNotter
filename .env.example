# Backend Configuration
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/maranotter
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d

# OpenAI API
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o
WHISPER_MODEL=whisper-1

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=maranotter-recordings

# AssemblyAI (Speaker Diarization)
ASSEMBLY_AI_KEY=your_assembly_ai_key

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# RevenueCat (Mobile In-App)
REVENUECAT_API_KEY=your_revenueat_api_key

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email
SMTP_PASS=your_app_password

# Frontend URLs
WEB_URL=http://localhost:3001
MOBILE_DEEPLINK=maranotter://

# Logging
LOG_LEVEL=info
SENTRY_DSN=your_sentry_dsn
